import java.util.*;
public class Combination {

	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		String str = sc.next();
		int l = str.length();
		for(int i = 1; i < (1<<l);i++) {
			String res = "";
			for(int sh = 0; sh < l; sh++) {
				if((i&(1<<sh))>0) {
					res += str.charAt(sh);
				}
			}
			System.out.println(res);
		}

	}

}
